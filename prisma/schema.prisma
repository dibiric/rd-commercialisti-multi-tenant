generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Site {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  slug        String   @unique

  name        String
  ownerName   String
  email       String
  phone       String?

  about       String?

  services    Service[]

  template    TemplateType

  heroTitle   String?
  heroSubtitle String?

  logoUrl     String?
  coverUrl    String?
}

model Service {
  id        String   @id @default(cuid())
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  siteId    String
  title     String
  description String?
  icon      String?
}

enum TemplateType {
  MINIMAL_TECH
  ELEGANT_CORPORATE
}

